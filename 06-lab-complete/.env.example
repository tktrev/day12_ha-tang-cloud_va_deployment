# Copy to .env.local and fill in real values
# ❌ DO NOT commit .env.local to Git

# ── Server ──────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false

# ── App ─────────────────────────────────────────
APP_NAME=Production AI Agent
APP_VERSION=1.0.0

# ── LLM ──────────────────────────────────────────
# Leave empty to use mock LLM
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Security — REQUIRED in production ────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_API_KEY=change-me-in-production
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Rate Limiting ────────────────────────────────
# Max requests per user per minute
RATE_LIMIT_PER_MINUTE=10

# ── Budget (per user per month) ──────────────────
DAILY_BUDGET_USD=10.0
GLOBAL_DAILY_BUDGET_USD=50.0

# Token pricing (per 1K tokens — GPT-4o-mini rates)
PRICE_PER_1K_INPUT_TOKENS=0.15
PRICE_PER_1K_OUTPUT_TOKENS=0.60

# ── Storage ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Session ──────────────────────────────────────
SESSION_TTL_SECONDS=3600
MAX_HISTORY_MESSAGES=20